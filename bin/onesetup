#!/usr/bin/env bash

# exit on error, undefined variables, and failed commands in pipes
set -euo pipefail 
# -- TERMINAL COLORS -- #
export C_BLACK='\033[1;30m'
export C_RED='\033[1;31m'
export C_GREEN='\033[1;32m'
export C_YELLOW='\033[1;33m'
export C_BLUE='\033[1;34m'
export C_PURPLE='\033[1;35m'
export C_CYAN='\033[1;36m'
export C_WHITE='\033[1;37m'
export C_GRAY='\033[1;34m'
export C_RESET='\033[0m'
# -- INFO PROMPTS -- #
export I_SKIP="${C_BLACK}[${C_CYAN} SKIPPING ${C_BLACK}] ${C_RESET}" # skipping
export I_WARN="${C_BLACK}[${C_YELLOW} WARNING ${C_BLACK}] ${C_RESET}" # warning
export I_OK="${C_BLACK}[${C_GREEN}  OK  ${C_BLACK}] ${C_RESET}" # ok
export I_INFO="${C_BLACK}[${C_PURPLE} INFO ${C_BLACK}] ${C_RESET}" # info
export I_ERR="${C_BLACK}[${C_YELLOW} ERROR ${C_BLACK}] ${C_RESET}" # error
export I_YN="${C_BLACK}[${C_BLUE} y/n ${C_BLACK}] ${C_RESET}" # ask user for yes/no
export I_ASK="${C_BLACK}[${C_BLUE} ? ${C_BLACK}] ${C_RESET}" # ask user for anything
export I_LOAD="${C_BLACK}[${C_BLUE} LOADING .. ${C_BLACK}] ${C_RESET}" # ask user for anything
# -- ENV VARS -- #
export ONESETUP="/opt/onesetup" && echo -e "${I_INFO} \$ONESETUP >>> $ONESETUP"
export ONEVAULT="${ONEVAULT:-/opt/onevault}" && echo -e "${I_INFO} \$ONEVAULT >>> $ONEVAULT"
export ANSIBLE_INVENTORY="${ONESETUP}/inventory.ini" && echo -e "${I_INFO} \$ANSIBLE_INVENTORY >>> $ANSIBLE_INVENTORY"
export ANSIBLE_CONFIG="${ONESETUP}/ansible.cfg" && echo -e "${I_INFO} \$ANSIBLE_CONFIG >>> $ANSIBLE_CONFIG"
export ONESETUP_BAK="/opt/.onesetup.BAK" && echo -e "${I_INFO} \$ONESETUP_BAK >>> $ONESETUP_BAK"

# -- USER GUIDE -- #
# get path to onesetup.secret file
if [[ -z $ONESETUP_SECRET ]]; then
  echo -e "${I_INFO} \$ONESETUP_SECRET environment variable not set >>> using default"
else
  echo -e "${I_INFO} \$ONESETUP_SECRET environment variable set >>> overwriting default"
fi
# user instructions (explained in README.md more detailed)
echo -e "${I_INFO}onesetup allows you to securely store secrets by using ansible vault:"
echo -e "${I_INFO}STEP 1: Generate the onesetup.secret file that only contains the ansible-vault master-password and nothing else. no whitespaces, no line breaks, !only the password!"
echo -e "${I_INFO}STEP 2: Set environment variable \$ONESETUP_SECRET to the path where you store onesetup.secret"
echo -e "${I_INFO}\$ONESETUP_SECRET >>> ${C_CYAN}$ONESETUP_SECRET ${C_RESET}(see README.md if you're confused)"
echo -e "${I_WARNING}This is your master secret file. Store it in a secure place and additionally save the secret string in a password manager. If you loose the file and the password, you are fucked."

# -- FUNCTIONS -- #
run_playbook() {
  local skip_tags="${1:-}"
  echo -e "${I_GO} onesetup ==> running ansible playbook"
  # initialize homebrew
  eval "$(/opt/homebrew/bin/brew shellenv)"
  # run ansible playbook with optional --skip-tags
  if [ -n "$skip_tags" ]; then
    ansible-playbook "${ONESETUP}/main.yml" --ask-become-pass --ask-vault-pass --skip-tags "$skip_tags" &&
      echo -e "${I_DONE} onesetup ==> ansible playbook finished" || echo -e "${I_ERR} onesetup ==> ansible playbook failed"
  else
    ansible-playbook "${ONESETUP}/main.yml" --ask-become-pass --ask-vault-pass &&
      echo -e "${I_DONE} onesetup ==> ansible playbook finished" || echo -e "${I_ERR} onesetup ==> ansible playbook failed"
  fi
}

# -- MAIN -- #
skip_tags=""
while [[ $# -gt 0 ]]; do
  case $1 in
  --skip)
    skip_tags="$2"
    shift 2
    ;;
  *)
    echo -e "${I_ERR} Unknown option: $1"
    exit 1
    ;;
  esac
done

run_playbook "$skip_tags"
