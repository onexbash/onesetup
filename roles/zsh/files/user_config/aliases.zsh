#!/usr/bin/env zsh
# -- BUILTIN -- #
alias cl="clear"
alias tc="touch"
alias md="mkdir"
alias gr="grep"
alias sr="source"
alias ns="netstat"
alias xa="xargs"
# -- TOOLS -- #
alias nv="nvim"
alias cr="cargo"
alias pa="pass"
alias ll="ollama"
# alias exif="exiftool"
alias pc="pass show -c"
alias br="brew"
alias py="python"
alias ku="kubectl" # kubernetes
alias ae="aerospace" # twm
alias lg="lazygit"
alias pn="pnpm"
alias zj="zellij"
alias ff="fastfetch"
alias ct="bat --color=always"
alias xc="pbcopy"
alias xp="pbpaste"
alias pg="nvimpager"
alias an="ansible"
alias an-pl="ansible-playbook"
alias tf="terraform"
alias pw="pwsh"
alias lz="/bin/ls"
alias fz='nvim $(fzf -m --preview="bat --color=always {}")'

# -- DROP IN REPLACEMENTS -- #
alias python3="python"
alias pip3="pip"
alias ssh="ssh -A"
alias grep="grep -i"
alias ls="eza --color=always --long --grid --no-filesize --icons=always --no-time --no-user --no-permissions --octal-permissions"

# -- CUSTOMS -- #
alias fs="filesize"
